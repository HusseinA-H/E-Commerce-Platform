# Port configuration
PORT=5000

# SQL Server database connection URL for Prisma
DATABASE_URL="sqlserver://localhost:1433;database=apexluxe;user=SA;password=StrongPassword123!;encrypt=true;trustServerCertificate=true"

# Security keys for auth
JWT_SECRET="your_jwt_secret_key"
JWT_EXPIRES_IN="900s"
JWT_REFRESH_SECRET="your_refresh_token_secret_key"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis caching setup
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="your_redis_password"

# Stripe payments configuration
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Cloudinary image hosting
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Groq API configuration for LLM interactions
GROQ_API_KEY="gsk_..."

# Email notifications configuration
MAIL_HOST="smtp.mailtrap.io"
MAIL_PORT=2525
MAIL_USER="your_mailtrap_user"
MAIL_PASS="your_mailtrap_password"
MAIL_FROM="noreply@yourdomain.com"

# Throttling rate limit rules
THROTTLER_TTL=60
THROTTLER_LIMIT=100
